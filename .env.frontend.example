# ─────────────────────────────────────────────────────────────
# Configuration FRONTEND — Pharmacie Backend RDC
# Copier ce fichier vers le projet frontend :
#   cp .env.frontend.example .env
#
# RÈGLE : choisir UN seul mode selon comment le backend a été démarré
# ─────────────────────────────────────────────────────────────

# ══════════════════════════════════════════════════════════════
# MODE TUNNEL (backend : npm run start:tunnel) — proxy Vite recommandé
# ══════════════════════════════════════════════════════════════
VITE_API_MODE=tunnel
VITE_API_URL=/api
VITE_WS_URL=https://pharmacie.loophole.site
VITE_PROXY_TARGET=https://pharmacie.loophole.site

# ══════════════════════════════════════════════════════════════
# MODE LOCAL (backend : npm run start:dev)
# Décommenter ce bloc et commenter le bloc TUNNEL
# ══════════════════════════════════════════════════════════════
# VITE_API_MODE=local
# VITE_API_URL=/api
# VITE_WS_URL=http://localhost:3000
# VITE_PROXY_TARGET=http://localhost:3000

# Hostname tunnel personnalisé (si TUNNEL_HOSTNAME ≠ pharmacie côté backend) :
# VITE_API_URL=/api
# VITE_WS_URL=https://VOTRE-HOSTNAME.loophole.site
# VITE_PROXY_TARGET=https://VOTRE-HOSTNAME.loophole.site

# ── MODE DÉMO ─────────────────────────────────────────────────────────────────
VITE_MOCK_MODE=false
VITE_HTTP_CLIENT=fetch
