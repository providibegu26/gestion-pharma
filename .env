# URL de l'API backend (laisser vide en dev = proxy Vite vers /api)
# VITE_API_URL=https://pharmacie.loophole.site/api

# ── MODE DÉMO ─────────────────────────────────────────────────────────────────
# true  → données mockées en mémoire (pas besoin du backend)
# false → communication réelle avec le backend
VITE_MOCK_MODE=false

# ── Implémentation HTTP utilisée quand VITE_MOCK_MODE=false ─────────────────────
# 'fetch' (défaut) → fetch natif équivalent (zéro dépendance HTTP runtime)
# 'axios'          → axios + intercepteur refresh
# 'mock'           → équivalent à VITE_MOCK_MODE=true (forcer le mock)
VITE_HTTP_CLIENT=fetch
