# ── Configuration FRONTEND — voir GUIDE_FRONTEND.md §2 ───────────────────────
# Backend start:tunnel → mode tunnel (proxy Vite vers loophole.site)
VITE_API_MODE=tunnel
VITE_API_URL=/api
VITE_WS_URL=https://pharmacie.loophole.site
VITE_PROXY_TARGET=https://pharmacie.loophole.site

# Backend start:dev (local) → décommenter ce bloc à la place :
# VITE_API_MODE=local
# VITE_API_URL=/api
# VITE_WS_URL=http://localhost:3000
# VITE_PROXY_TARGET=http://localhost:3000

# ── MODE DÉMO ─────────────────────────────────────────────────────────────────
VITE_MOCK_MODE=false
VITE_HTTP_CLIENT=fetch
