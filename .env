# ── Mode API (documentation) ──────────────────────────────────────────────────
# local  → backend lancé avec `npm run start:dev`
# tunnel → backend lancé avec `npm run start:tunnel` (Loophole)
VITE_API_MODE=tunnel

# ── URL de l'API ──────────────────────────────────────────────────────────────
# Laisser vide en dev → proxy Vite (/api) vers VITE_PROXY_TARGET (voir ci-dessous).
# VITE_API_URL=http://localhost:3000/api
# VITE_API_URL=https://pharmacie.loophole.site/api

# ── Cible du proxy Vite (dev) ───────────────────────────────────────────────────
# Bascule local ↔ tunnel SANS toucher au code. Proxifie /api ET /socket.io.
# VITE_PROXY_TARGET=http://localhost:3000
VITE_PROXY_TARGET=https://pharmacie.loophole.site

# ── WebSocket temps réel (Socket.IO) ───────────────────────────────────────────
# Socket.IO se connecte DIRECTEMENT au backend (pas via le proxy Vite).
# → Toujours pointer l'URL absolue du backend, quelle que soit VITE_API_URL.
# Vide → temps réel désactivé (l'app reste fonctionnelle, toasts/polling désactivés).
# VITE_WS_URL=http://localhost:3000
VITE_WS_URL=https://pharmacie.loophole.site

# ── MODE DÉMO ─────────────────────────────────────────────────────────────────
# true  → données mockées en mémoire (pas besoin du backend)
# false → communication réelle avec le backend
VITE_MOCK_MODE=false

# ── Implémentation HTTP utilisée quand VITE_MOCK_MODE=false ─────────────────────
# 'fetch' (défaut) → fetch natif équivalent (zéro dépendance HTTP runtime)
# 'axios'          → axios + intercepteur refresh
# 'mock'           → équivalent à VITE_MOCK_MODE=true (forcer le mock)
VITE_HTTP_CLIENT=fetch
