# ── URL de l'API ──────────────────────────────────────────────────────────────
# En dev, laisser vide (proxy Vite utilisé automatiquement) → /api
# VITE_API_URL=
#
# En production, pointer vers le backend déployé
# VITE_API_URL=https://pharmacie.loophole.site/api

# ── MODE DÉMO (mocks en mémoire) ──────────────────────────────────────────────
# true  → toutes les requêtes sont interceptées par MockHttpClient
# false → communication réelle avec le backend (axios ou fetch selon VITE_HTTP_CLIENT)
VITE_MOCK_MODE=false

# ── Implémentation HTTP réelle (ignorée si VITE_MOCK_MODE=true) ────────────────
# Bascule axios ↔ fetch SANS modifier la moindre ligne de code applicatif.
# - fetch (par défaut) → fetch natif équivalent (zéro dépendance HTTP runtime)
# - axios              → instance axios avec intercepteur de refresh
# - mock               → force le MockHttpClient (équivalent à VITE_MOCK_MODE=true)
VITE_HTTP_CLIENT=fetch
