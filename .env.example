# ── Base de données ──────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/pharmacie_db?schema=public"

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET="changez-moi-minimum-32-caracteres-secrets"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="changez-moi-aussi-minimum-32-caracteres"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Serveur ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
PHARMACIE_NOM="Pharmacie Centrale Gombe"
TUNNEL_HOSTNAME=pharmacie

# ── CORS (optionnel en dev — défauts dans main.ts si absent) ─
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Email Gmail (obligatoire au démarrage de l'application) ─
GMAIL_USER="votre-compte@gmail.com"
GMAIL_APP_PASSWORD="mot-de-passe-application-16-caracteres"

# ── Seed — comptes de démonstration ──────────────────────────
SEED_DEFAULT_PASSWORD="pharma2026"
# Compte ADMIN (gestion des comptes uniquement) : admin@pharmacie-centrale.cd

# Mettre à true pour supprimer toutes les données et recréer le jeu de démo
# SEED_FORCE=true
