# ─────────────────────────────────────────────────────────────────────────────
#  Configuration FRONTEND — Pharmacie Digital
#  Copier vers .env :  cp .env.example .env
#  Règle d'or : l'URL du front doit correspondre au MODE de démarrage du backend
#    - backend `npm run start:dev`    → local  (localhost:3000)
#    - backend `npm run start:tunnel` → tunnel (pharmacie.loophole.site)
# ─────────────────────────────────────────────────────────────────────────────

# ── Mode API (documentation) ──────────────────────────────────────────────────
VITE_API_MODE=local

# ── URL de l'API ──────────────────────────────────────────────────────────────
# En dev, laisser vide → proxy Vite (/api) vers VITE_PROXY_TARGET.
# En prod / accès direct, décommenter la bonne ligne :
# VITE_API_URL=http://localhost:3000/api
# VITE_API_URL=https://pharmacie.loophole.site/api

# ── Cible du proxy Vite (dev uniquement) ───────────────────────────────────────
# Proxifie /api ET /socket.io. Basculer local ↔ tunnel ici, sans toucher au code.
VITE_PROXY_TARGET=http://localhost:3000
# VITE_PROXY_TARGET=https://pharmacie.loophole.site

# ── WebSocket temps réel (Socket.IO) ───────────────────────────────────────────
# Socket.IO se connecte DIRECTEMENT au backend (pas via le proxy Vite).
# Toujours pointer l'URL absolue du backend.  Vide = temps réel désactivé.
# VITE_WS_URL=http://localhost:3000
# VITE_WS_URL=https://pharmacie.loophole.site

# ── MODE DÉMO (mocks en mémoire) ──────────────────────────────────────────────
# true  → toutes les requêtes sont interceptées par MockHttpClient (sans backend)
# false → communication réelle avec le backend (axios ou fetch selon VITE_HTTP_CLIENT)
VITE_MOCK_MODE=false

# ── Implémentation HTTP réelle (ignorée si VITE_MOCK_MODE=true) ────────────────
# Bascule axios ↔ fetch SANS modifier la moindre ligne de code applicatif.
# - fetch (par défaut) → fetch natif équivalent (zéro dépendance HTTP runtime)
# - axios              → instance axios avec intercepteur de refresh
# - mock               → force le MockHttpClient (équivalent à VITE_MOCK_MODE=true)
VITE_HTTP_CLIENT=fetch
